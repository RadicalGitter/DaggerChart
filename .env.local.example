# Copy values into .env.local. That file is intentionally ignored by Git.
SUNO_API_KEY=

# Use mock for local UI work without spending credits; switch to live when ready.
SUNO_MODE=mock
# SUNO_API_URL=
# SUNO_CALLBACK_URL=https://your-public-host/api/music/provider/callback
# MUSIC_LIBRARY_DIR=
# FFMPEG_PATH=ffmpeg
# MUSIC_WORLD_THEME_TITLE=Vessa'rin

# The Anthropic writing aids (background expansions, portrait briefs).
# ANTHROPIC_API_KEY=

# Address beacon — publishes the server's current public IP/port so players
# can reach it after your home IP changes. Off unless a target is configured.
# Recommended: DuckDNS gives a stable hostname (keeps installed PWAs and HTTPS
# working across IP changes). See docs/remote-access.md.
# BEACON_INTERVAL_MINUTES=15
# BEACON_DUCKDNS_DOMAIN=yourtable          # the label before .duckdns.org
# BEACON_DUCKDNS_TOKEN=
# A private gist as a "password-protected note" of the current address:
# BEACON_GIST_ID=
# BEACON_GITHUB_TOKEN=                      # a token with the "gist" scope only
